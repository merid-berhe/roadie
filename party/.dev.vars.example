# PartyKit local dev secrets — copy to .dev.vars and fill in values.
# .dev.vars is gitignored; never commit real keys.
#
# Get your fal.ai key at https://fal.ai/dashboard/keys
# Set MOCK_MUSIC=true to skip real generation entirely (no fal.ai charges).
# The room still transitions through all phases — music just won't play.
FAL_KEY=
MOCK_MUSIC=false
