# Supabase — fill these to enable anonymous auth + persistence.
# M0 runs locally WITHOUT them (falls back to a local UUID identity).
# Copy to app/.env.local and paste your project values.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Maps — for Photorealistic 3D Tiles (Paris proof of concept in ?scene=1)
# Enable "Map Tiles API" in Google Cloud Console, then paste your key here.
VITE_GOOGLE_MAPS_KEY=